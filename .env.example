# DNS MCP Server Configuration
# Copy to .env and customize

# Bearer token for proxy authentication (CHANGE THIS)
MCP_BEARER_TOKEN=YOUR_BEARER_TOKEN_HERE

# Ports (host-side)
MCP_PORT=8083
PROXY_PORT=8082

# Log path on host for fail2ban access
LOG_PATH=/var/log/mcp-proxy
# if you are on a mac uncomment this line
# LOG_PATH=./logs
